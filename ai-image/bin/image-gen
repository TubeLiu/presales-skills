#!/usr/bin/env bash
# Thin wrapper for ai-image's image_gen.py.
# Self-locates via BASH_SOURCE so it works regardless of plugin cache layout
# (local marketplace, remote marketplace with versioned cache, etc.).
set -e
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec python3 "$SCRIPT_DIR/../scripts/image_gen.py" "$@"
