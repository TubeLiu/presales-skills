#!/usr/bin/env bash
# SessionStart hook for Solution Master plugin
#
# Adapted from superpowers-zh/hooks/session-start (MIT, jnMetaCode)
# Source commit: 4a55cbf9f348ba694cf5cbf4d56df7340ff2b74f
#
# Changes from upstream:
#   - Variable rename: PLUGIN_ROOT -> SM_ROOT
#   - Read skills/go/SKILL.md (the unified main SKILL after M4 11→1 merge)
#   - Injected text adapted to Solution Master context
#   - Added project-gate: only fires in Solution Master projects
#     (presence of drafts/, docs/specs/, or solution-master skill marker)

set -euo pipefail

# Determine plugin root directory (self-locating)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SM_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# -------- Project gate --------
# Only inject context when the current project looks like a Solution Master
# project. This prevents the hook from polluting non-SM projects when the
# plugin is installed globally.
PROJECT_DIR="${CLAUDE_PROJECT_DIR:-$PWD}"
if [ ! -d "${PROJECT_DIR}/drafts" ] && \
   [ ! -d "${PROJECT_DIR}/docs/specs" ] && \
   [ ! -f "${PROJECT_DIR}/skills/go/SKILL.md" ] && \
   [ ! -f "${PROJECT_DIR}/.claude/skills/go/SKILL.md" ]; then
  exit 0
fi

# Read main solution-master SKILL content (post M4 11→1 merge: iron rules now live here)
using_sm_content=$(cat "${SM_ROOT}/skills/go/SKILL.md" 2>&1 || echo "Error reading solution-master skill")

# Escape string for JSON embedding via Python json.dumps — full RFC 8259 coverage
# including all control chars U+0000–U+001F (F-022 fix).
#
# 历史：原本用 bash 参数替换链，仅覆盖 7 种最常见 escape；用户 SKILL.md 偶尔粘入
# 二进制片段或控制字符时会破坏 JSON。改用 python3 json.dumps，stdin 读取避开 argv
# 尺寸限制 + ensure_ascii=False 保中文为字面字符（输出更紧凑）。
#
# python3 在 solution-master plugin 全流程已是必备依赖（sm_config.py / kb_indexer.py），
# 不引入新依赖。
escape_for_json() {
    printf '%s' "$1" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read(), ensure_ascii=False)[1:-1], end="")'
}

using_sm_escaped=$(escape_for_json "$using_sm_content")
session_context="<EXTREMELY_IMPORTANT>\nYou are operating Solution Master — an AI 辅助通用解决方案撰写框架.\n\n**Below is the full content of your 'solution-master:solution-master' skill — your introduction to Solution Master's iron rules, red lines, workflow navigation, and subagent dispatch. For other skills, use the 'Skill' tool:**\n\n${using_sm_escaped}\n</EXTREMELY_IMPORTANT>"

# Output context injection as JSON.
#
# Cursor hooks expect `additional_context` at the top level.
# Claude Code hooks expect `hookSpecificOutput.additionalContext` — this is
# the documented API and is also what Solution Master's npx installer relies
# on (the SessionStart hook is registered via settings.json, where
# CLAUDE_PLUGIN_ROOT is NOT set, so the script falls through to the
# default branch).
#
# Therefore: Cursor is detected via CURSOR_PLUGIN_ROOT, everything else
# defaults to Claude Code format (which covers both plugin mode, npx mode,
# and direct invocation for testing).
#
# Uses printf instead of heredoc (cat <<EOF) to work around a bash 5.3+
# bug where heredoc variable expansion hangs when content exceeds ~512 bytes.
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$session_context"
else
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context"
fi

exit 0
